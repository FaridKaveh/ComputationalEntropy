Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"totalEnt", "[", "M_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"F", " ", "=", 
       RowBox[{"1", "/", "M"}]}], "}"}], ",", " ", 
     RowBox[{
      RowBox[{"F", "/", "2"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "k"}], "/", "2"}], "*", "F"}], "]"}], "/", 
         RowBox[{"Sinh", "[", 
          RowBox[{
           RowBox[{"k", "/", "2"}], "*", "F"}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "1", ",", "M"}], "}"}]}], "]"}]}]}], " ", "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.96279866857742*^9, 3.962798680050743*^9}, {
  3.9627987349262*^9, 3.962798809001131*^9}, {3.962798848995616*^9, 
  3.9627989858607397`*^9}, {3.962799035845053*^9, 3.962799038758033*^9}, {
  3.962800434217897*^9, 3.962800450032118*^9}, {3.9628648038685923`*^9, 
  3.962864808039222*^9}},
 CellLabel->"In[29]:=",ExpressionUUID->"0cdfadfd-db10-4094-a10c-183d67658ff1"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"approximatingIntegral", "[", "M_", "]"}], ":=", 
   RowBox[{
    RowBox[{"1", "/", "2"}], "*", " ", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "x"}], "/", "2"}], "]"}], "/", 
       RowBox[{"Sinh", "[", 
        RowBox[{"x", "/", "2"}], "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", 
        RowBox[{"1", "/", "M"}], ",", "1"}], "}"}]}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.962864601106042*^9, 3.962864651456496*^9}, {
  3.962864717349861*^9, 3.962864720267348*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"cfe9b915-53b1-4ecc-8891-f6df7ee70b59"],

