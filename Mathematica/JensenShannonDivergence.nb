Cell[BoxData[
 RowBox[{
  RowBox[{"EntropySum", "[", 
   RowBox[{"n_", ",", "M_"}], "]"}], " ", ":=", " ", 
  RowBox[{"NSum", "[", 
   RowBox[{
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"k", " ", "!=", "0"}], ",", 
      RowBox[{
       RowBox[{"3", "/", "M"}], "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"NrateRatio", "[", 
           RowBox[{"M", ",", "k"}], "]"}], "-", 
          RowBox[{"n", "*", 
           RowBox[{
            RowBox[{"NrateRatio", "[", 
             RowBox[{"M", ",", "k"}], "]"}], "^", "n"}]}], "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}], "*", 
           RowBox[{
            RowBox[{"NrateRatio", "[", 
             RowBox[{"M", ",", "k"}], "]"}], "^", 
            RowBox[{"(", 
             RowBox[{"n", "+", "1"}], ")"}]}]}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{"NrateRatio", "[", 
             RowBox[{"M", ",", "k"}], "]"}]}], ")"}], 
          RowBox[{"(", 
           RowBox[{"1", "-", 
            RowBox[{
             RowBox[{"NrateRatio", "[", 
              RowBox[{"M", ",", "k"}], "]"}], "^", "n"}]}], ")"}]}], 
         ")"}]}]}], ",", 
      RowBox[{"3", "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"2", "*", "M"}], ")"}]}]}]}], "]"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"k", ",", 
      RowBox[{"-", "M"}], ",", "M"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.963988167325585*^9, 3.963988174603494*^9}, {
  3.963988473648376*^9, 3.963988506453641*^9}},
 CellLabel->"In[21]:=",ExpressionUUID->"6ed972c2-0a2c-4653-8911-5a12dd2ac024"],

