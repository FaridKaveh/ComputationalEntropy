Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"phi", "[", 
    RowBox[{"n_", ",", "c_", ",", "x_"}], "]"}], ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"x", "!=", "0"}], ",", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "c"}], "*", "x"}], "]"}], "-", 
        RowBox[{"n", "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "n"}], "*", "c", "*", "x"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", "-", "1"}], ")"}], "*", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"n", "+", "1"}], ")"}]}], "*", "c", "*", "x"}], 
          "]"}]}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "c"}], "*", "x"}], "]"}]}], ")"}], "*", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "n"}], "*", "c", "*", "x"}], "]"}]}], ")"}]}], 
       ")"}]}], ",", " ", 
     RowBox[{
      RowBox[{"1", "/", "2"}], "*", 
      RowBox[{"(", 
       RowBox[{"n", "-", "1"}], ")"}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9645269354957027`*^9, 3.9645270411884212`*^9}, {
  3.964527309880662*^9, 3.964527311225654*^9}, {3.964527368825979*^9, 
  3.9645274273730288`*^9}, {3.964527611419448*^9, 3.96452763139231*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"417605de-0fa5-4069-877e-7543e95f6647"],

