Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"NtotalEntProd", "[", 
    RowBox[{"n_", ",", "M_"}], "]"}], ":=", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"NadjacentDistsKLD", "[", 
      RowBox[{"n", ",", "M", ",", "k"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", 
       RowBox[{"-", "M"}], ",", "M"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.962956463914411*^9, 3.962956488906864*^9}, {
