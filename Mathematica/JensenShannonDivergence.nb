Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Sum", "[", 
   RowBox[{
    RowBox[{"j", "*", 
     RowBox[{"x", "^", "j"}]}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"j", ",", "0", ",", 
      RowBox[{"N", "-", "1"}]}], "}"}]}], "]"}], "//", 
  "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.962799849127027*^9, 3.962799867427294*^9}, {
  3.9628000256239023`*^9, 3.962800028980204*^9}},
 CellLabel->"In[35]:=",ExpressionUUID->"7d66deab-7019-4e78-9320-252654926c98"],

Cell[BoxData[
 FractionBox[
  RowBox[{"x", "+", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"N", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "x"}], ")"}]}], "-", "x"}], ")"}], " ", 
    SuperscriptBox["x", "N"]}]}], 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "1"}], "+", "x"}], ")"}], "2"]]], "Output",
 CellChangeTimes->{3.96279986883121*^9, 3.962800029282818*^9, 
  3.962864110865468*^9, 3.9629555571431103`*^9},
 CellLabel->"Out[35]=",ExpressionUUID->"8a328bec-5313-4faf-ba21-a393375f1edd"]
}, Open  ]],

