Cell["\<\
Below  I\[CloseCurlyQuote]m doing some analysis to observe the scaling with M \
and N, setting \[Delta] = 1/e^3 ~ 0.05 for simplicity. I use n in place of N \
because Mathematica has a built in function called N. \
\>", "Text",
 CellChangeTimes->{{3.96295574111044*^9, 3.962955804722444*^9}, {
  3.962955907428469*^9, 
  3.962955932831938*^9}},ExpressionUUID->"ffa5b892-481a-41d2-800b-\
0b3c1ac03dc2"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{
   RowBox[{
   "piN", " ", "is", " ", "the", " ", "probability", " ", "mass", " ", "in", 
    " ", "the", " ", "n"}], "-", 
   RowBox[{"th", " ", "state", " ", "after", " ", "k", " ", "steps"}]}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.9629558215709133`*^9, 3.96295584077721*^9}, {
  3.962955903088982*^9, 3.962955903223662*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"f9bcfef4-f421-45de-a444-316a75155930"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"rateRatio", "[", 
    RowBox[{"M_", ",", "c_", ",", "k_"}], "]"}], ":=", " ", 
   RowBox[{"Exp", "[", 
    RowBox[{
     RowBox[{"-", "c"}], "*", 
     RowBox[{"k", "/", "M"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.962956052534322*^9, 3.9629561253912163`*^9}, {
  3.962956362382557*^9, 3.962956362544512*^9}, {3.9639217466537347`*^9, 
  3.963921760864881*^9}, {3.964673707014398*^9, 3.964673732345096*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"fe181887-32d8-4269-8007-b5f547beec6b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"adjacentDistsKLD", "[", 
    RowBox[{"n_", ",", "M_", ",", "c_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"k", " ", "!=", "0"}], ",", 
     RowBox[{
      RowBox[{"c", "/", "M"}], "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"rateRatio", "[", 
          RowBox[{"M", ",", "c", ",", "k"}], "]"}], "-", 
         RowBox[{"n", "*", 
          RowBox[{
           RowBox[{"rateRatio", "[", 
            RowBox[{"M", ",", "c", ",", "k"}], "]"}], "^", "n"}]}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"n", "-", "1"}], ")"}], "*", 
          RowBox[{
           RowBox[{"rateRatio", "[", 
            RowBox[{"M", ",", "c", ",", "k"}], "]"}], "^", 
           RowBox[{"(", 
            RowBox[{"n", "+", "1"}], ")"}]}]}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{"rateRatio", "[", 
            RowBox[{"M", ",", "c", ",", "k"}], "]"}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           RowBox[{
            RowBox[{"rateRatio", "[", 
             RowBox[{"M", ",", "c", ",", "k"}], "]"}], "^", "n"}]}], ")"}]}], 
        ")"}]}]}], ",", 
     RowBox[{"c", "*", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"n", "-", "1"}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", "*", "M"}], ")"}]}]}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.962955577683612*^9, 3.962955605817758*^9}, {
   3.962955962984242*^9, 3.962955963645849*^9}, {3.96295603292729*^9, 
   3.962956039843032*^9}, {3.962956154166628*^9, 3.962956356018748*^9}, {
   3.962958283938503*^9, 3.962958297585471*^9}, {3.962959192290588*^9, 
   3.962959251324928*^9}, {3.962959400654308*^9, 3.962959417583211*^9}, 
   3.962961471995742*^9, {3.962963104721301*^9, 3.962963131069347*^9}, 
   3.963381766002376*^9, {3.96467375103161*^9, 3.964673778824689*^9}, {
   3.964674170852787*^9, 3.9646741854906273`*^9}, 3.964674462444092*^9},
 CellLabel->"In[21]:=",ExpressionUUID->"ce76f93c-3149-40bd-ba1a-262239ab7edf"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"totalEntProd", "[", 
    RowBox[{"n_", ",", "M_", ",", "c_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      RowBox[{"(", 
       RowBox[{"n", "-", "1"}], ")"}]}], "*", "c"}], "+", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"adjacentDistsKLD", "[", 
       RowBox[{"n", ",", "M", ",", "c", ",", "k"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", 
        RowBox[{"-", "M"}], ",", "M"}], "}"}]}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.962956463914411*^9, 3.962956488906864*^9}, {
   3.962956938733854*^9, 3.962956949982134*^9}, {3.962956981762672*^9, 
   3.962956989816043*^9}, {3.962961832389873*^9, 3.962961832597637*^9}, {
   3.963921695280287*^9, 3.9639216985324726`*^9}, 3.963921764641383*^9, {
   3.964673782983144*^9, 3.964673789298339*^9}, {3.96467446553881*^9, 
   3.964674473605918*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"5e390a24-a2c2-4690-ae5c-2f94dda11f01"],

