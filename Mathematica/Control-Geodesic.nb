Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", 
    RowBox[{"x_", ",", "n_"}], "]"}], ":=", " ", 
   RowBox[{"Log", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "n"}], "*", "x"}], "]"}]}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"Exp", "[", 
        RowBox[{"-", "x"}], "]"}]}], ")"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.974718211637253*^9, 3.9747182500311327`*^9}, {
  3.974718887511607*^9, 3.974718889037492*^9}, {3.974719010928815*^9, 
  3.9747190255284653`*^9}},
 CellLabel->"In[32]:=",ExpressionUUID->"a99ababa-7d23-4f71-a19e-bf503f76144e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Derivative", "[", 
     RowBox[{"2", ",", "0"}], "]"}], "[", "f", "]"}], "[", 
   RowBox[{"x", ",", "n"}], "]"}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.974718250802923*^9, 3.974718270965374*^9}, {
  3.974718336657895*^9, 3.974718368847488*^9}, {3.974718874398356*^9, 
  3.974718892153543*^9}, {3.9747190690112343`*^9, 3.9747190701775227`*^9}, {
  3.974719103196145*^9, 3.974719106258903*^9}},
 CellLabel->"In[22]:=",ExpressionUUID->"5aa570a8-70c1-43d5-8c33-42373fe5bc6c"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", "x"], "+", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"x", "+", 
     RowBox[{"2", " ", "n", " ", "x"}]}]], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"n", " ", "x"}]], " ", 
    SuperscriptBox["n", "2"]}], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"2", "+", "n"}], ")"}], " ", "x"}]], " ", 
    SuperscriptBox["n", "2"]}], "+", 
   RowBox[{"2", " ", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"x", "+", 
      RowBox[{"n", " ", "x"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["n", "2"]}], ")"}]}]}], 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["\[ExponentialE]", "x"]}], ")"}], "2"], " ", 
   SuperscriptBox[
    RowBox[{"(", 
     RowBox[{
      RowBox[{"-", "1"}], "+", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"n", " ", "x"}]]}], ")"}], "2"]}]]], "Output",
 CellChangeTimes->{
  3.9747182714369183`*^9, {3.974718365737895*^9, 3.974718369220689*^9}, 
   3.9747188938924847`*^9, 3.974718925431559*^9, 3.9747190280572767`*^9, 
   3.9747190707566357`*^9, 3.974719106505121*^9},
 CellLabel->"Out[22]=",ExpressionUUID->"8b07a2f5-1f56-47cd-8ce4-c42a793a6d92"]
}, Open  ]],

