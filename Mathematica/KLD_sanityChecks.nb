Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Phi]", "[", 
    RowBox[{"n_", ",", "x_"}], "]"}], ":=", " ", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{"x", "!=", "1"}], ",", 
     FractionBox[
      RowBox[{"x", "-", 
       RowBox[{"n", "*", 
        RowBox[{"x", "^", "n"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], 
        RowBox[{"x", "^", 
         RowBox[{"(", 
          RowBox[{"n", "+", "1"}], ")"}]}]}]}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", "x"}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"x", "^", "n"}]}], ")"}]}]], ",", " ", 
     FractionBox[
      RowBox[{"n", "-", "1"}], "2"]}], "]"}]}], ";"}]], "Input",
