Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"phiPrime", "[", 
     RowBox[{"n_", ",", "x_"}], "]"}], " ", "=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"x", "!=", "1"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"Derivative", "[", 
         RowBox[{"0", ",", "1"}], "]"}], "[", "\[Phi]", "]"}], "[", 
       RowBox[{"n", ",", "x"}], "]"}], ",", 
      RowBox[{
       RowBox[{"1", "/", "12"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"n", "^", "2"}], "-", "1"}], ")"}]}]}], "]"}]}], ";"}], 
  " "}]], "Input",
