Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"phiApproxLimit", "[", 
    RowBox[{"n_", ",", "x_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"-", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"n", "-", "1"}], ")"}], 
        RowBox[{"Exp", "[", 
         RowBox[{"n", "*", "x"}], "]"}]}], "-", 
       RowBox[{"n", "*", 
        RowBox[{"Exp", "[", 
         RowBox[{"n", "*", "x"}], "]"}]}], "+", "1"}], ")"}]}], "/", 
    RowBox[{"(", 
     RowBox[{"x", 
      RowBox[{"(", 
       RowBox[{"1", "-", "x"}], ")"}], 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", 
         RowBox[{"n", "*", "x"}], "]"}]}], ")"}]}], ")"}]}]}], ";"}]], "Input",\

 CellChangeTimes->{{3.9709127634685383`*^9, 3.970912774467065*^9}, {
   3.970912932733493*^9, 3.970913006619914*^9}, 3.970913858057612*^9},
