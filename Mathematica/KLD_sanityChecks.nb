Cell[BoxData[
 RowBox[{
  RowBox[{"upperBarriers", " ", "=", " ", 
   RowBox[{"ParallelTable", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", 
       RowBox[{"NSolve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"\[Phi]", "[", 
            RowBox[{"n", ",", "x"}], "]"}], "==", 
           RowBox[{
            RowBox[{"3", "/", "4"}], "*", 
            RowBox[{"(", 
             RowBox[{"n", "-", "1"}], ")"}]}]}], "&&", 
          RowBox[{"x", ">", "0"}]}], ",", " ", "x", ",", " ", "Reals", ",", 
         " ", 
         RowBox[{"WorkingPrecision", "->", "100"}]}], "]"}]}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", "5", ",", "80"}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.968480637229587*^9, 3.968480767085314*^9}, {
  3.968480798220954*^9, 3.96848082846734*^9}, {3.968480862560828*^9, 
