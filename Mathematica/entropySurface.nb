Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Ensure", " ", "C", " ", "compilation", " ", "is", " ", "available"}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"Needs", "[", "\"\<CCompilerDriver`\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"cfRateRatio", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"M", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "_Real"}], "}"}]}], "}"}], ",", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "c"}], "*", 
         RowBox[{"k", "/", "M"}]}], "]"}], ",", 
       RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
       RowBox[{"RuntimeAttributes", "->", 
        RowBox[{"{", "Listable", "}"}]}], ",", 
       RowBox[{"Parallelization", "->", "True"}], ",", 
       RowBox[{"CompilationOptions", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<ExpressionOptimization\>\"", "->", "True"}], "}"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"cfAdjacentDistsKLD", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"n", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"M", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "_Real"}], "}"}]}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"r", "=", 
            RowBox[{"cfRateRatio", "[", 
             RowBox[{"M", ",", "c", ",", "k"}], "]"}]}], ",", "numerator", 
           ",", "denom1", ",", "denom2"}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"k", "!=", "0."}], ",", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"numerator", "=", 
              RowBox[{"r", "-", 
               RowBox[{"n", "*", 
                RowBox[{"r", "^", "n"}]}], "+", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"n", "-", "1"}], ")"}], "*", 
                RowBox[{"r", "^", 
                 RowBox[{"(", 
                  RowBox[{"n", "+", "1"}], ")"}]}]}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"denom1", "=", 
              RowBox[{"1.", "-", "r"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"denom2", "=", 
              RowBox[{"1.", "-", 
               RowBox[{"r", "^", "n"}]}]}], ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"c", "/", "M"}], ")"}], "*", 
              RowBox[{"(", 
               RowBox[{"numerator", "/", 
                RowBox[{"(", 
                 RowBox[{"denom1", "*", "denom2"}], ")"}]}], ")"}]}]}], ")"}],
            ",", 
           RowBox[{"c", "*", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", "-", "1"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"2.", "*", "M"}], ")"}]}]}]}], "]"}]}], "]"}], ",", 
       RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
       RowBox[{"RuntimeAttributes", "->", 
        RowBox[{"{", "Listable", "}"}]}], ",", 
       RowBox[{"Parallelization", "->", "True"}], ",", 
       RowBox[{"CompilationOptions", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<ExpressionOptimization\>\"", "->", "True"}], "}"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"cfTotalEntProd", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"n", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"M", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "_Real"}], "}"}]}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"sum", "=", "0."}], "}"}], ",", 
         RowBox[{
          RowBox[{"Do", "[", 
           RowBox[{
            RowBox[{"sum", "+=", 
             RowBox[{"cfAdjacentDistsKLD", "[", 
              RowBox[{"n", ",", "M", ",", "c", ",", "k"}], "]"}]}], ",", 
            RowBox[{"{", 
             RowBox[{"k", ",", 
              RowBox[{"-", "M"}], ",", "M"}], "}"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"n", "-", "1"}], ")"}]}], "*", "c"}], "+", "sum"}]}]}], 
        "]"}], ",", 
       RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
       RowBox[{"RuntimeAttributes", "->", 
        RowBox[{"{", "}"}]}], ",", 
       RowBox[{"Parallelization", "->", "False"}], ",", 
       RowBox[{"CompilationOptions", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<ExpressionOptimization\>\"", "->", "True"}], "}"}]}]}], 
      "]"}]}], ";"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.964674876162067*^9, 3.964674876162339*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"7527eba3-2bfd-4de0-bae0-af6aa3dde028"]
},
